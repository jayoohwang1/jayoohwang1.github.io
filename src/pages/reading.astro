---
import BaseLayout from '../layouts/BaseLayout.astro';
import ReadingItem from '../components/ReadingItem.astro';
import readingData from '../data/reading.json';

interface Item {
  title: string;
  url: string;
  note: string;
  children: Item[];
}

interface Subsection {
  title: string;
  count: number;
  items: Item[];
}

interface Section {
  title: string;
  count: number;
  items: Item[];
  subsections: Subsection[];
}

const sections = readingData.sections as Section[];
---
<BaseLayout title="Reading">
  <h1>Reading</h1>
  <p>
    A running log of papers I'm reading or have read, grouped by topic.
    Click a section to expand it.
  </p>

  <div class="reading">
    {sections.map((section) => (
      <details class="section" open={section.title === 'Agent'}>
        <summary>
          <span class="section-title">{section.title}</span>
          <span class="count">{section.count}</span>
        </summary>
        <div class="section-body">
          {section.items.length > 0 && (
            <ul class="item-list">
              {section.items.map((item) => <ReadingItem item={item} />)}
            </ul>
          )}
          {section.subsections.map((sub) => (
            <details class="subsection">
              <summary>
                <span class="subsection-title">{sub.title}</span>
                <span class="count">{sub.count}</span>
              </summary>
              <ul class="item-list">
                {sub.items.map((item) => <ReadingItem item={item} />)}
              </ul>
            </details>
          ))}
        </div>
      </details>
    ))}
  </div>
</BaseLayout>
