---
import Self from './ReadingItem.astro';

interface Item {
  title: string;
  url: string;
  note: string;
  children: Item[];
}

interface Props {
  item: Item;
}

const { item } = Astro.props;
const hasChildren = item.children.length > 0;
// Items without a URL act as mini-headers — collapsed by default.
const startOpen = item.url !== '';
---
{hasChildren ? (
  <li class="has-children">
    <details open={startOpen}>
      <summary>
        {item.url ? <a href={item.url}>{item.title}</a> : <span>{item.title}</span>}
        {item.note && <>{' '}<span class="note">{item.note}</span></>}
      </summary>
      <ul class="item-list">
        {item.children.map((child) => <Self item={child} />)}
      </ul>
    </details>
  </li>
) : (
  <li>
    {item.url ? <a href={item.url}>{item.title}</a> : <span>{item.title}</span>}
    {item.note && <>{' '}<span class="note">{item.note}</span></>}
  </li>
)}
